# Copia este archivo a .env y ajusta los valores. NO subir .env al repositorio.

# ----- PostgreSQL -----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=logistics
POSTGRES_PORT=5432

# ----- Redis -----
REDIS_PORT=6379

# ----- API -----
ASPNETCORE_ENVIRONMENT=Development
API_PORT=8080

# ----- JWT (firma de tokens) -----
JWT_ISSUER=Logistics.Api
JWT_AUDIENCE=Logistics.Client
# Debe tener al menos 32 caracteres para HS256.
JWT_KEY=CHANGE_ME_super_secret_dev_signing_key_min_32_chars

# ----- Usuario Admin por defecto (seed) -----
ADMIN_EMAIL=admin@logistics.com
ADMIN_PASSWORD=Admin123!
