{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=logistics;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Issuer": "Logistics.Api",
    "Audience": "Logistics.Client",
    "Key": "CHANGE_ME_super_secret_dev_signing_key_min_32_chars"
  },
  "AdminUser": {
    "Name": "Administrator",
    "Email": "admin@logistics.com",
    "Password": "Admin123!"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/logistics-.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{CorrelationId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
